{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "cd frontend && npm install && npm run build",
  "functions": {
    "api/index.js": {
      "includeFiles": "src/**,public/ui/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
