{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "rewrites": [
    { "source": "/ui/assets/(.*)", "destination": "/ui/assets/$1" },
    { "source": "/ui/(.*)",        "destination": "/ui/index.html" },
    { "source": "/(.*)",           "destination": "/api" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
