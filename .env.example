# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── GHL Marketplace App Credentials ─────────────────────
# Get these from: https://marketplace.gohighlevel.com → My Apps → Your App → Settings
GHL_CLIENT_ID=your_ghl_client_id_here
GHL_CLIENT_SECRET=your_ghl_client_secret_here

# Must match the redirect URI registered in your Marketplace App
GHL_REDIRECT_URI=https://claudeserver.vercel.app/oauth/callback

# ─── Webhook Signature Verification ──────────────────────
# RSA public key from: Marketplace App → Settings → Webhook Authentication
# Paste the full PEM key with literal \n for newlines
GHL_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkq...\n-----END PUBLIC KEY-----"

# ─── OAuth Login Window Mode ──────────────────────────────
# 'popup' (default) or 'self' (same tab)
GHL_LOGIN_WINDOW_MODE=popup

# ─── Store ────────────────────────────────────────────────
# Path to the JSON file used as a simple token store
# Replace with a real DB (Postgres, MongoDB, Redis) in production
STORE_PATH=./data/store.json

# ─── Anthropic / Claude AI ────────────────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── Upstash Redis (production key storage) ───────────────
# Create a free database at https://console.upstash.com
# More secure than local JSON file — required for production/Vercel
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── Firebase Admin SDK (tool API key storage) ────────────
# Stores per-location API keys (Perplexity, OpenAI, SendGrid, etc.)
# encrypted with AES-256-GCM. Keys never touch this .env file.
#
# Setup:
#   1. Go to https://console.firebase.google.com → Project Settings → Service accounts
#   2. Click "Generate new private key" → download the JSON file
#   3. Copy the three fields below from the JSON
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key value (escape newlines as \n):
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----"

# AES-256-GCM encryption key for Firestore values (defence in depth).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters.
TOOL_ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# ─── Admin Dashboard ──────────────────────────────────────
# Separate key for /admin/* routes. Never share with sub-account users.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_admin_api_key_here

# Session secret for Admin Dashboard credential tokens (8h JWT-style HMAC tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=your_dashboard_session_secret_here

# Public URL of your app (used to build activation email links)
APP_URL=https://yourapp.example.com

# ─── SMTP (for Admin Dashboard activation emails) ────────
# Supports any SMTP provider (Gmail, SendGrid SMTP, Mailgun, etc.)
# Leave SMTP_HOST unset in development — emails will be logged to console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="HL Pro Tools" <noreply@yourapp.com>

# ─── MCP Server (for Claude Code / Claude Desktop) ────────
# Set these when running the MCP server (node mcp-server.js)
# Not needed for the Express web server
MCP_LOCATION_ID=your_ghl_location_id
MCP_COMPANY_ID=your_ghl_company_id

# ─── OpenAI (optional — voice transcription + content gen) ─
# Used for Whisper voice-to-text on /claude/voice endpoint
# Also configurable per-location in the dashboard UI
OPENAI_API_KEY=sk-your_openai_key_here
